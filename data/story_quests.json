          ],
          "endDialogues": [],
          "rewards": {
            "money": 800,
            "exp": 300
          },
          "targetCount": 1
        },
        {
          "step": 3,
          "name": "虚空降临",
          "description": "深入【永夜深渊】，决战虚空魔神·混沌！",
          "type": "boss_battle",
          "targetId": 33,
          "targetCount": 1,
          "startDialogues": [
            {
              "character": "虚空教团首领",
              "avatar": "npc_oracle",
              "text": "来不及了，卑微的蝼蚁！伟大的混沌已经降临！"
            },
            {
              "character": "虚空魔神·混沌",
