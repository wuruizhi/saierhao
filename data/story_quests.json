          "type": "boss_battle",
          "targetId": 21,
          "targetCount": 1,
          "startDialogues": [
            { "character": "焱龙帝·炎皇", "avatar": "boss_21", "text": "吼！是谁闯入了我的领地？是你们这些贪婪的铁皮人吗！" },
            { "character": "玩家", "avatar": "player", "text": "等一下，我们不是海盗！我们是来帮忙的！" },
            { "character": "焱龙帝·炎皇", "avatar": "boss_21", "text": "证明你的实力，我才会相信你！来吧，接受烈火的洗礼！" }
          ],
          "endDialogues": [
            { "character": "焱龙帝·炎皇", "avatar": "boss_21", "text": "好强大的力量与意志。我相信你，年轻的赛尔。" },
            { "character": "焱龙帝·炎皇", "avatar": "boss_21", "text": "海盗已经被我赶走了，这个【火之印记】交给你，愿无尽能源的希望与你同在。" },
            { "character": "玩家", "avatar": "player", "text": "谢谢你，炎帝猩！我一定会找到无尽能源的！" }
          ],
          "rewards": { "money": 3000, "items": { "capsule_master": 1 } }
        }
      ]
    },
