          "targetId": [1, 10, 17],
          "targetCount": 3,
          "startDialogues": [
            { "character": "船长罗杰", "avatar": "rogers", "text": "小赛尔，火焰星的活火山突然开始异常喷发，原本温和的火系精灵变得非常狂躁。" },
            { "character": "船长罗杰", "avatar": "rogers", "text": "据探测仪显示，是宇宙海盗在火山核心秘密开采地核能源。你去调查一下吧！" },
            { "character": "玩家", "avatar": "player", "text": "收到！我这就前往火焰星的熔岩入口。" }
          ],
          "endDialogues": [
            { "character": "玩家", "avatar": "player", "text": "呼，终于让这些小家伙冷静下来了。收集到了足够的熔岩结晶。" }
          ],
          "rewards": { "money": 1000, "exp": 500 }
        },
        {
          "step": 1,
          "name": "海盗踪迹",
          "description": "深入【烈焰峡谷】，击败2只高等级火系精灵，驱逐海盗的爪牙。",
          "type": "battle",
          "targetId": [1, 2, 10, 17],
          "targetCount": 2,
          "startDialogues": [
            { "character": "派特博士", "avatar": "pete", "text": "干得好！从结晶分析来看，地核能量正在被快速抽离。海盗肯定就在附近。" },
            { "character": "玩家", "avatar": "player", "text": "我听到【烈焰峡谷】那边有机器轰鸣的声音，我去看看。" }
          ],
          "endDialogues": [
            { "character": "玩家", "avatar": "player", "text": "海盗的钻探设备被破坏了！他们逃往火山核心了，不能让他们得逞！" }
          ],
          "rewards": { "money": 1500, "exp": 800 }
        },
        {
          "step": 2,
